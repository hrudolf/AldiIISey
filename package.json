{
  "name": "aldiiisey",
  "version": "1.0.0",
  "description": "Galactic Spacefarer Adventure takeaway exercise",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hrudolf/AldiIISey.git"
  },
  "license": "MIT",
  "private": true,
  "author": "hrudolf",
  "dependencies": {
    "@sap/cds": "^9.8.4",
    "@sap/cds-common-content": "^3.1.0",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "handlebars": "^4.7.9",
    "nodemailer": "^8.0.4"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@cap-js/cds-types": "^0.16.0",
    "@cap-js/sqlite": "^2.2.0",
    "cds-plugin-ui5": "^0.13.0"
  },
  "scripts": {
    "start": "cds serve",
    "watch": "cds watch",
    "watch-spacefarers-view": "cds watch --open spacefarersview/index.html?sap-ui-xx-viewCache=false --livereload false"
  },
  "cds": {
    "requires": {
      "auth": {
        "impl": "./srv/custom-auth.js"
      },
      "db": {
        "kind": "sqlite",
        "credentials": {
          "url": "db/aldiiisey.db"
        }
      }
    }
  },
  "workspaces": [
    "app/*"
  ],
  "sapux": [
    "app/spacefarers-view"
  ]
}
