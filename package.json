{
  "name": "aldiiisey",
  "version": "1.0.0",
  "description": "Galactic Spacefarer Adventure takeaway exercise",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hrudolf/AldiIISey.git"
  },
  "license": "MIT",
  "private": true,
  "author": "hrudolf",
  "dependencies": {
    "@sap/cds": "^9.8.4",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "nodemailer": "^8.0.4"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@cap-js/cds-types": "^0.16.0",
    "@cap-js/sqlite": "^2.2.0",
    "cds-plugin-ui5": "^0.13.0"
  },
  "scripts": {
    "start": "cds serve",
    "watch": "cds watch",
    "watch-spacefarers-view": "cds watch --open spacefarersview/index.html?sap-ui-xx-viewCache=false --livereload false"
  },
  "cds": {
    "requires": {
      "auth": {
        "kind": "basic",
        "users": {
          "admin": {
            "password": "admin",
            "roles": [
              "Admin"
            ]
          },
          "user": {
            "password": "user",
            "roles": [
              "authenticated-user"
            ],
            "attr": {
              "spacefarer_ID": "31304918-7a00-46cc-bba3-b227c167ab75"
            }
          }
        }
      }
    }
  },
  "workspaces": [
    "app/*"
  ],
  "sapux": [
    "app/spacefarers-view"
  ]
}
